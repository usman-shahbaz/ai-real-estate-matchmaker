"""
AI Data Analysis Agent
Powered by GPT-4o, Phidata, and DuckDB
"""

import json
import tempfile
import csv
import re
import streamlit as st
import pandas as pd
from phi.model.openai import OpenAIChat
from phi.agent.duckdb import DuckDbAgent
from phi.tools.pandas import PandasTools

from utils.file_processor import preprocess_and_save
from utils.ui_helpers import render_sidebar, render_header, render_query_result


# ── Page config ──────────────────────────────────────────────────────────────
st.set_page_config(
    page_title="AI Data Analyst Agent",
    page_icon="📊",
    layout="wide",
    initial_sidebar_state="expanded",
)

render_header()
render_sidebar()

# ── File upload ───────────────────────────────────────────────────────────────
st.markdown("### 📤 Upload Your Data File")
uploaded_file = st.file_uploader(
    "Supported formats: CSV, Excel (.xlsx)",
    type=["csv", "xlsx"],
    help="Upload the data file you want to analyse.",
)

if uploaded_file is not None:
    with st.spinner("Processing file…"):
        temp_path, columns, df = preprocess_and_save(uploaded_file)

    if df is not None:
        st.success(f"✅ File loaded successfully — **{len(df):,} rows × {len(columns)} columns**")

        with st.expander("🔍 Preview uploaded data", expanded=True):
            st.dataframe(df, use_container_width=True)
            st.caption(f"Columns detected: `{'`, `'.join(columns)}`")

        # ── Semantic model for DuckDB ─────────────────────────────────────────
        semantic_model = {
            "tables": [
                {
                    "name": "uploaded_data",
                    "description": (
                        "Contains the user-uploaded dataset. "
                        f"Columns: {', '.join(columns)}."
                    ),
                    "path": temp_path,
                }
            ]
        }

        # ── Guard: require API key ────────────────────────────────────────────
        if "openai_key" not in st.session_state or not st.session_state.openai_key:
            st.warning("⚠️ Please enter your OpenAI API key in the sidebar to continue.")
            st.stop()

        # ── Initialise DuckDB Agent ───────────────────────────────────────────
        @st.cache_resource(show_spinner=False)
        def get_agent(api_key: str, semantic_model_json: str) -> DuckDbAgent:
            return DuckDbAgent(
                model=OpenAIChat(model="gpt-4o", api_key=api_key),
                semantic_model=semantic_model_json,
                tools=[PandasTools()],
                markdown=True,
                system_prompt=(
                    "You are an expert data analyst. "
                    "When given a natural-language question about the data, "
                    "generate and execute the correct DuckDB SQL query, "
                    "then present the results clearly with a brief explanation. "
                    "Always prefer readable column aliases and limit large result sets to 50 rows "
                    "unless the user explicitly requests more."
                ),
            )

        agent = get_agent(
            api_key=st.session_state.openai_key,
            semantic_model_json=json.dumps(semantic_model),
        )

        # ── Query interface ───────────────────────────────────────────────────
        st.markdown("---")
        st.markdown("### 💬 Ask a Question About Your Data")

        example_queries = [
            "Show me the first 10 rows",
            "What are the summary statistics?",
            "Which column has the most null values?",
            "Show the top 5 values by count for each categorical column",
        ]

        with st.expander("💡 Example queries", expanded=False):
            for q in example_queries:
                if st.button(q, key=q):
                    st.session_state.prefill_query = q

        user_query = st.text_area(
            "Enter your query:",
            value=st.session_state.get("prefill_query", ""),
            height=100,
            placeholder="e.g. What is the average sales per region?",
        )

        col1, col2 = st.columns([1, 5])
        submit = col1.button("🚀 Submit", use_container_width=True)
        col2.button(
            "🗑️ Clear",
            use_container_width=False,
            on_click=lambda: st.session_state.pop("prefill_query", None),
        )

        if submit:
            if not user_query.strip():
                st.warning("Please enter a query before submitting.")
            else:
                with st.spinner("Analysing your data…"):
                    try:
                        response = agent.run(user_query)
                        render_query_result(user_query, response)

                        # Persist query history
                        if "query_history" not in st.session_state:
                            st.session_state.query_history = []
                        st.session_state.query_history.append(
                            {"query": user_query, "response": str(response)}
                        )
                    except Exception as exc:
                        st.error(f"❌ Error running query: {exc}")

        # ── Query history ─────────────────────────────────────────────────────
        if st.session_state.get("query_history"):
            with st.expander(
                f"📜 Query History ({len(st.session_state.query_history)} queries)",
                expanded=False,
            ):
                for i, item in enumerate(reversed(st.session_state.query_history), 1):
                    st.markdown(f"**{i}.** `{item['query']}`")
                    st.markdown(item["response"])
                    st.divider()
